---
interface Props {
  text?: string
}

const { text = "If this SDK saves you time, consider giving it a star — it helps other developers discover the project." } =
  Astro.props
---

<aside class="star-cta not-content">
  <div class="star-cta-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
    </svg>
  </div>
  <div class="star-cta-body">
    <p class="star-cta-title">Enjoying Telegram Bot SDK?</p>
    <p class="star-cta-text">{text}</p>
  </div>
  <a
    class="star-cta-btn"
    href="https://github.com/kondaurovDev/tg-bot-sdk"
    target="_blank"
    rel="noopener"
  >
    <svg width="16" height="16" viewBox="0 0 98 96" aria-hidden="true">
      <path
        fill-rule="evenodd"
        clip-rule="evenodd"
        d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
        fill="currentColor"
      />
    </svg>
    Star on GitHub
    <span class="star-cta-count" data-star-cta-count></span>
  </a>
</aside>

<script>
  const CACHE_KEY = "gh-stars"
  const TTL = 60 * 60 * 1000

  function show(count: number) {
    for (const el of document.querySelectorAll("[data-star-cta-count]")) {
      el.textContent = String(count)
    }
  }

  function fetchStars() {
    fetch("https://api.github.com/repos/kondaurovDev/tg-bot-sdk")
      .then((r) => r.json())
      .then((data) => {
        if (typeof data.stargazers_count === "number") {
          show(data.stargazers_count)
          sessionStorage.setItem(CACHE_KEY, JSON.stringify({ count: data.stargazers_count, ts: Date.now() }))
        }
      })
      .catch(() => {})
  }

  const cached = sessionStorage.getItem(CACHE_KEY)
  if (cached) {
    const { count, ts } = JSON.parse(cached)
    show(count)
    if (Date.now() - ts >= TTL) fetchStars()
  } else {
    fetchStars()
  }
</script>

<style>
  .star-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid color-mix(in srgb, #e3b341 30%, var(--sl-color-hairline));
    border-radius: 0.9rem;
    background: color-mix(in srgb, #e3b341 5%, transparent);
  }

  .star-cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.7rem;
    background: color-mix(in srgb, #e3b341 15%, transparent);
    color: #e3b341;
  }

  .star-cta-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .star-cta-body {
    flex: 1;
    min-width: 14rem;
  }

  .star-cta-title {
    margin: 0;
    font-weight: 600;
    font-size: var(--sl-text-base);
    color: var(--sl-color-white);
  }

  .star-cta-text {
    margin: 0.2rem 0 0;
    font-size: var(--sl-text-sm);
    line-height: 1.5;
    color: var(--sl-color-gray-3);
  }

  .star-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      color 0.15s ease;
  }

  .star-cta-btn:hover {
    border-color: #e3b341;
    color: #e3b341;
    background: rgba(227, 179, 65, 0.08);
  }

  .star-cta-count:not(:empty)::before {
    content: "";
    display: inline-block;
    width: 1px;
    height: 0.9em;
    margin-right: 0.5rem;
    vertical-align: -0.1em;
    background: var(--sl-color-hairline);
  }
</style>
