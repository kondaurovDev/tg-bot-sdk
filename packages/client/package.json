{
  "name": "@effect-ak/tg-bot-client",
  "version": "1.7.0",
  "description": "Type-safe HTTP client for Telegram Bot API",
  "keywords": [
    "http-client",
    "telegram",
    "telegram-bot",
    "telegram-bot-api",
    "typescript"
  ],
  "homepage": "https://tg-bot-sdk.website",
  "license": "MIT",
  "author": {
    "name": "Aleksandr Kondaurov",
    "email": "kondaurov.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kondaurovDev/tg-bot-sdk",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/*": "./dist/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect-ak/tg-bot-api": "workspace:^"
  }
}
